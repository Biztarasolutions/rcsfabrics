{
  "name": "rcsfabrics-backend",
  "version": "1.0.0",
  "description": "RCS Fabrics Backend API - Premium Luxury Fabric Ecommerce Platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --loader tsconfig-paths/loader dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "npx prisma db seed"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": ["express", "typescript", "api", "ecommerce"],
  "author": "RCS Fabrics",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "tsconfig-paths": "^4.2.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "stripe": "^14.5.0",
    "nodemailer": "^6.9.7",
    "aws-sdk": "^2.1563.0",
    "sharp": "^0.32.6",
    "razorpay": "^2.9.2",
    "module-alias": "^2.2.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/nodemailer": "^6.4.14",
    "@types/morgan": "^1.9.9"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "tsx": "^4.6.2",
    "prisma": "^5.7.0",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2"
  },
  "_moduleAliases": {
    "@": "dist"
  }
}
