generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique @db.VarChar(255)
  password      String     @db.VarChar(255)
  firstName     String?    @db.VarChar(100)
  lastName      String?    @db.VarChar(100)
  phone         String?    @db.VarChar(20)
  avatar        String?
  role          UserRole   @default(CUSTOMER)
  isActive      Boolean    @default(true)
  isVerified    Boolean    @default(false)
  verifyToken   String?
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  addresses     Address[]
  cart          CartItem[]
  orders        Order[]
  reviews       Review[]
  wishlist      Wishlist[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  firstName  String   @db.VarChar(100)
  lastName   String   @db.VarChar(100)
  phone      String   @db.VarChar(20)
  email      String   @db.VarChar(255)
  street     String   @db.VarChar(255)
  city       String   @db.VarChar(100)
  state      String   @db.VarChar(100)
  postalCode String   @db.VarChar(20)
  country    String   @db.VarChar(100)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique @db.VarChar(200)
  slug        String    @unique @db.VarChar(200)
  description String?
  image       String?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  gender      String    @default("women")
  bestFor     String[]  @default([])
  properties  String[]  @default([])

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

model Collection {
  id          String              @id @default(cuid())
  name        String              @unique @db.VarChar(200)
  slug        String              @unique @db.VarChar(200)
  description String?
  image       String?
  isActive    Boolean             @default(true)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    CollectionProduct[]

  @@index([slug])
  @@index([isActive])
  @@map("collections")
}

model Product {
  id              String              @id @default(cuid())
  name            String              @db.VarChar(255)
  slug            String              @unique @db.VarChar(255)
  description     String?
  categoryId      String
  code            Int?
  styleCode       String?             @db.VarChar(100)
  basePrice       Float
  discountPrice   Float?
  discountPercent Float?
  discountType    String?             @db.VarChar(20) // "percentage" or "fixed"
  discountValue   Float?
  material        String              @db.VarChar(100)
  gsm             Int?
  width           Float?
  pattern         String?             @db.VarChar(100)
  occasion        String?             @db.VarChar(100)
  workType        String?             @db.VarChar(50) // "Plain", "Printed", "Embroidered"
  color           String              @db.VarChar(50)
  stretchability  String              @db.VarChar(50)
  usage           String?
  washCare        String?
  totalStock      Float
  minOrderQty     Float               @default(0.5)
  sku             String?             @unique @db.VarChar(100)
  folderUrl       String?
  rating          Float               @default(0)
  ratingCount     Int                 @default(0)
  isActive        Boolean             @default(true)
  isFeatured      Boolean             @default(false)
  isNew           Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  cartItems       CartItem[]
  collections     CollectionProduct[]
  orderItems      OrderItem[]
  images          ProductImage[]
  category        Category            @relation(fields: [categoryId], references: [id])
  reviews         Review[]
  swatchRequests  SwatchRequest[]
  wishlist        Wishlist[]
  colors          ProductColor[]

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@index([isFeatured])
  @@index([isNew])
  @@index([isActive, isFeatured, createdAt])
  @@index([isActive, createdAt])
  @@index([categoryId, isActive])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?  @db.VarChar(255)
  order     Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  productId    String
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([productId])
  @@map("collection_products")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlist")
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       String         @unique @db.VarChar(50)
  userId            String
  shippingAddressId String?
  shippingAddress   String?
  subtotal          Float
  shippingCost      Float          @default(0)
  tax               Float          @default(0)
  discountAmount    Float          @default(0)
  couponCode        String?        @db.VarChar(50)
  total             Float
  status            OrderStatus    @default(PENDING)
  paymentStatus     PaymentStatus  @default(PENDING)
  paymentMethod     PaymentMethod?
  stripePaymentId   String?        @db.VarChar(255)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deliveredAt       DateTime?
  notes             String?
  paidAt            DateTime?
  razorpayOrderId   String?        @db.VarChar(255)
  razorpayPaymentId String?        @db.VarChar(255)
  trackingNumber    String?        @db.VarChar(255)
  items             OrderItem[]
  user              User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  productName   String   @db.VarChar(255)
  productImage  String?
  quantity      Float
  pricePerMeter Float
  total         Float
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?  @db.VarChar(255)
  comment    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([productId, createdAt])
  @@map("reviews")
}

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique @db.VarChar(50)
  description    String?
  discountType   DiscountType
  discountValue  Float
  maxDiscount    Float?
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  startsAt       DateTime
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model Banner {
  id        String    @id @default(cuid())
  title     String    @db.VarChar(255)
  subtitle  String?   @db.VarChar(255)
  image     String
  link      String?   @db.VarChar(255)
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
  @@map("banners")
}

model HomepageSection {
  id          String      @id @default(cuid())
  title       String      @db.VarChar(255)
  subtitle    String?
  sectionType SectionType
  isActive    Boolean     @default(true)
  order       Int         @default(0)
  data        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([sectionType])
  @@index([isActive])
  @@map("homepage_sections")
}

model SEOMetadata {
  id            String     @id @default(cuid())
  entityType    EntityType
  entityId      String     @db.VarChar(255)
  title         String?    @db.VarChar(255)
  description   String?
  keywords      String?
  ogImage       String?
  ogTitle       String?    @db.VarChar(255)
  ogDescription String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([entityType, entityId])
  @@map("seo_metadata")
}

model SwatchRequest {
  id        String       @id @default(cuid())
  productId String
  name      String       @db.VarChar(200)
  email     String       @db.VarChar(255)
  phone     String?      @db.VarChar(20)
  message   String?
  status    SwatchStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([status])
  @@map("swatch_requests")
}

model BulkOrderInquiry {
  id             String          @id @default(cuid())
  name           String          @db.VarChar(200)
  email          String          @db.VarChar(255)
  phone          String          @db.VarChar(20)
  company        String?         @db.VarChar(255)
  inquiryDetails String
  status         BulkOrderStatus @default(PENDING)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@map("bulk_order_inquiries")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   @db.VarChar(255)
  entity    String   @db.VarChar(100)
  entityId  String   @db.VarChar(255)
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@map("activity_logs")
}

enum UserRole {
  CUSTOMER
  ADMIN
  VENDOR
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  RAZORPAY
  BANK_TRANSFER
  COD
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum SectionType {
  FEATURED_PRODUCTS
  NEW_ARRIVALS
  TRENDING
  BEST_SELLERS
  FEATURED_COLLECTIONS
  CATEGORY_SHOWCASE
  TESTIMONIALS
  CUSTOM_HTML
}

enum EntityType {
  PRODUCT
  CATEGORY
  COLLECTION
  PAGE
}

enum SwatchStatus {
  PENDING
  APPROVED
  REJECTED
  SENT
}

enum BulkOrderStatus {
  PENDING
  UNDER_REVIEW
  QUOTED
  ACCEPTED
  REJECTED
}

model ProductColor {
  id          String   @id @default(cuid())
  productId   String
  name        String   @db.VarChar(50)
  hexCode     String   @db.VarChar(7)
  productCode String?  @db.VarChar(100) // Style Code-Color (e.g., "RAJ-SILK-RED")
  folderUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_colors")
}
